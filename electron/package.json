{
  "name": "thriveos",
  "version": "1.0.0",
  "description": "ThriveOS — your AI-powered browser for life and business",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.thriveos.app",
    "productName": "ThriveOS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "build/**"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "ThriveOS.dmg"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icons/icon.ico",
      "artifactName": "ThriveOS_installer.exe"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "icon": "build/icons/icon.png",
      "category": "Network",
      "artifactName": "ThriveOS.AppImage"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
